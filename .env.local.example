# Supabase (production — used by `next build` and Vercel)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key

# Database — find in Supabase: Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ─── Local development ────────────────────────────────────────
# Copy the block below into .env.development.local to use local Supabase.
# Run `supabase start` to get your local keys (they are stable across restarts).
#
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<publishable key from supabase start>
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
